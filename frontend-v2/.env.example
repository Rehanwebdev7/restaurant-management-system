# Spring Boot backend base URL (port 8091, context /rms)
VITE_API_BASE_URL=http://localhost:8091/rms

VITE_APP_VERSION=1.0.0
VITE_PLATFORM=web

# Optional integrations (left blank during early phases)
VITE_SENTRY_DSN=
VITE_FIREBASE_VAPID_KEY=
VITE_GOOGLE_MAPS_KEY=

# Payment gateways (UI-F-1). Leave blank to render mock/disabled fallbacks.
# Stripe: dashboard.stripe.com → Developers → API keys (use pk_test_… in dev).
VITE_STRIPE_PUBLISHABLE_KEY=
# PayPal: developer.paypal.com → My Apps & Credentials → Sandbox Client ID.
VITE_PAYPAL_CLIENT_ID=
# CCAvenue: merchant ID from CCAvenue dashboard. Access code + encrypted
# request payload are generated server-side and passed to the redirect form.
VITE_CCAVENUE_MERCHANT_ID=

# Mock adapter (legacy mock server). False for live backend.
VITE_ENABLE_MOCK=false
